{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/proxy.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/8kpro.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"8kpro.apk\"" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/proxy" },
    { "source": "/dl", "destination": "/api/dl" },
    { "source": "/((?!api/|8kpro\\.apk).*)", "destination": "/index.html" }
  ]
}
