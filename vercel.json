{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/proxy.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/proxy" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
